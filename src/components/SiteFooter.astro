---
import { navigation } from '../../config/navigation';
import { siteConfig } from '../../config/site';
import VisitCounter from './VisitCounter.astro';

interface Props {
  lang: 'ar' | 'en';
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const links = navigation[lang];
const siteName = lang === 'ar' ? siteConfig.nameAr : siteConfig.nameEn;
const description =
  lang === 'ar'
    ? 'موقع علمي ثنائي اللغة يجمع السيرة العلمية والكتب والتحقيقات والمقالات والمشروعات والروابط في بنية منظمة قابلة للنمو.'
    : 'A bilingual scholarly website bringing together academic profile, books, critical editions, articles, projects, and curated links in an organized structure.';
const quickLinks = links.slice(0, 6);
const extendedLinks = links.slice(6);
const siteIndexLink = lang === 'ar' ? '/ar/site-map/' : '/en/site-map/';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="shell site-footer__grid">
    <section>
      <p class="footer-kicker">{lang === 'ar' ? 'عن الموقع' : 'About the site'}</p>
      <h2 class="footer-title">{siteName}</h2>
      <p class="footer-copy">{description}</p>
    </section>

    <section>
      <p class="footer-kicker">{lang === 'ar' ? 'روابط سريعة' : 'Quick links'}</p>
      <div class="footer-links">
        {quickLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    </section>

    <section>
      <p class="footer-kicker">{lang === 'ar' ? 'أقسام التوسع' : 'Expansion Areas'}</p>
      <div class="footer-links">
        {extendedLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
        <a href={siteIndexLink}>{lang === 'ar' ? 'دليل الموقع' : 'Site Index'}</a>
      </div>
    </section>

    <section>
      <p class="footer-kicker">{lang === 'ar' ? 'الحالة الحالية' : 'Current status'}</p>
      <p class="footer-copy">
        {lang === 'ar'
          ? 'الموقع تجاوز مرحلة الصياغات التأسيسية في كثير من أقسامه، وتستمر فيه الآن إضافة المحتوى العلمي الفعلي والتحسينات التقنية.'
          : 'The site has moved beyond its earliest scaffold stage in many sections, and current work now focuses on real scholarly content and technical refinement.'}
      </p>
    </section>
  </div>

  <div class="shell site-footer__bottom">
    <p>{siteName}</p>
    <VisitCounter lang={lang} currentPath={currentPath} />
    <p>{year}</p>
  </div>
</footer>
