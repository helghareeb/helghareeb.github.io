---
import { getCollection, render } from 'astro:content';
import EntityEntryPage from '../../../components/EntityEntryPage.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import { getArticleSeriesPath, getEntryPath, getEntryRouteSlug } from '../../../utils/content-routing';
import { buildSeoDescription, buildSeoTitle } from '../../../utils/seo';

export async function getStaticPaths() {
  const entries = (await getCollection('articles')).filter((entry) => entry.data.lang === 'ar' && !entry.data.draft);

  return entries.map((entry) => ({
    params: { slug: getEntryRouteSlug(entry.slug) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const seriesEntries = entry.data.seriesSlug
  ? (await getCollection('articles'))
      .filter(
        (item) =>
          item.data.lang === 'ar' &&
          !item.data.draft &&
          item.data.seriesSlug === entry.data.seriesSlug,
      )
      .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0))
  : [];
const currentSeriesIndex = seriesEntries.findIndex((item) => item.id === entry.id);
const previousSeriesEntry = currentSeriesIndex > 0 ? seriesEntries[currentSeriesIndex - 1] : undefined;
const nextSeriesEntry =
  currentSeriesIndex >= 0 && currentSeriesIndex < seriesEntries.length - 1 ? seriesEntries[currentSeriesIndex + 1] : undefined;
const seoTitle = buildSeoTitle(entry.data.title, { lang: 'ar', section: 'المقالات' });
const seoDescription = buildSeoDescription(entry.data.summary, [
  entry.data.category,
  entry.data.sourceName,
  entry.data.series,
]);
---

<BaseLayout lang="ar" dir="rtl" title={seoTitle} description={seoDescription}>
  <EntityEntryPage
    lang="ar"
    eyebrow="مقال"
    title={entry.data.title}
    summary={entry.data.summary}
    badges={['صفحة مقال', entry.data.articleType ?? 'مقال', entry.data.category ?? 'تصنيف عام']}
    metaItems={[
      { label: 'القسم', value: 'المقالات' },
      ...(entry.data.date ? [{ label: 'التاريخ', value: entry.data.date }] : []),
      ...(entry.data.series ? [{ label: 'السلسلة', value: entry.data.series }] : []),
      ...(entry.data.sourceName ? [{ label: 'المصدر', value: entry.data.sourceName }] : []),
      ...(entry.data.readingTime ? [{ label: 'زمن القراءة', value: entry.data.readingTime }] : []),
    ]}
    backHref="/ar/articles/"
    backLabel="العودة إلى قسم المقالات"
    externalUrl={entry.data.externalUrl}
    externalLabel="رابط المقال"
  >
    <Content />

    {entry.data.sourceName && entry.data.externalUrl && (
      <section class="notice-card">
        <p class="entity-kicker">النشر الأصلي</p>
        <h2 class="section-title">المقال منشور أيضًا على {entry.data.sourceName}</h2>
        <p>
          هذه الصفحة تُظهر نسخة داخلية منظمة من المقال ضمن أرشيف الموقع، بينما يظل النشر
          الأصلي متاحًا على {entry.data.sourceName}.
        </p>
        <p>
          <a href={entry.data.externalUrl}>الانتقال إلى المقال على {entry.data.sourceName}</a>
        </p>
      </section>
    )}

    {entry.data.seriesSlug && (
      <div class="section section--soft">
        <p class="entity-kicker">داخل السلسلة</p>
        <div class="section-heading">
          <h2 class="section-title">متابعة قراءة السلسلة</h2>
          <p class="section-copy">
            تنتمي هذه المقالة إلى سلسلة منظمة داخل الموقع، ويمكن الرجوع إلى فهرس السلسلة
            أو الانتقال إلى الحلقة السابقة أو التالية عند توفرها.
          </p>
        </div>

        <div class="hero__actions">
          <a class="button-secondary" href={getArticleSeriesPath('ar', entry.data.seriesSlug)}>
            عرض فهرس السلسلة
          </a>
          {previousSeriesEntry && (
            <a class="button-secondary" href={getEntryPath('articles', 'ar', previousSeriesEntry.slug)}>
              الحلقة السابقة
            </a>
          )}
          {nextSeriesEntry && (
            <a class="button-secondary" href={getEntryPath('articles', 'ar', nextSeriesEntry.slug)}>
              الحلقة التالية
            </a>
          )}
        </div>
      </div>
    )}
  </EntityEntryPage>
</BaseLayout>
