---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import { getArticleSeriesPath, getEntryPath } from '../../../utils/content-routing';

const allArticles = (await getCollection('articles'))
  .filter((entry) => entry.data.lang === 'ar' && !entry.data.draft)
  .sort((a, b) => {
    const aTime = a.data.date ? new Date(a.data.date).getTime() : 0;
    const bTime = b.data.date ? new Date(b.data.date).getTime() : 0;

    return bTime - aTime;
  });

const articles = allArticles
  .slice(0, 6);

const seriesMap = new Map<
  string,
  {
    title: string;
    slug: string;
    count: number;
  }
>();

for (const article of allArticles) {
  if (!article.data.series || !article.data.seriesSlug) continue;

  const existing = seriesMap.get(article.data.seriesSlug);

  if (existing) {
    existing.count += 1;
  } else {
    seriesMap.set(article.data.seriesSlug, {
      title: article.data.series,
      slug: article.data.seriesSlug,
      count: 1,
    });
  }
}

const featuredSeries = Array.from(seriesMap.values())
  .sort((a, b) => b.count - a.count)
  .slice(0, 3);
---

<BaseLayout
  lang="ar"
  dir="rtl"
  title="المقالات | د. هيثم الغريب"
  description="قسم المقالات والسلاسل العلمية ضمن الموقع الشخصي العلمي"
>
  <main class="page-main">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">المقالات</p>
      <h1 class="hero__title">أرشفة المقالات والسلاسل العلمية</h1>
      <p class="hero__lead">
        خُصص هذا القسم ليكون واجهة النشر المتجدد في الموقع، وليجمع المقالات الأصلية
        والمقالات المنشورة خارجيًا والسلاسل الموضوعية في بنية منظمة سهلة التصفح والرجوع.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">مقالات أصلية</span>
        <span class="hero__badge">سلاسل علمية</span>
        <span class="hero__badge">أرشفة منظمة</span>
      </div>
    </section>

    <section class="shell entity-grid">
      <article class="entity-summary">
        <p class="entity-kicker">وظيفة القسم</p>
        <h2 class="section-title">مساحة للنشر والتوثيق المستمر</h2>
        <p class="section-copy">
          سيجمع هذا الأرشيف المقالات الأصلية، والكتابات المرتبطة بسلاسل علمية، والمواد ذات
          الصلة بالنشر الخارجي، ضمن بنية تسهل الرجوع والربط بين الموضوعات.
        </p>
        <ul class="entity-tags">
          <li>تاريخ النشر</li>
          <li>التصنيف</li>
          <li>السلسلة</li>
          <li>المصدر</li>
        </ul>
      </article>

      <article class="entity-panel">
        <p class="entity-kicker">جاهزية العرض</p>
        <ul class="entity-list">
          <li><strong>الحالة الحالية:</strong> بطاقات وصفحات مفردة للمقالات، مع سلسلة مستوردة ومنظمة داخل الموقع.</li>
          <li><strong>التطوير القادم:</strong> مزيد من المقالات والوسوم والتصنيفات عند الحاجة.</li>
          <li><strong>الهدف:</strong> جعل القسم مرجعًا حيًا للنشر العلمي والمعرفي.</li>
        </ul>
      </article>
    </section>

    <section class="shell section">
      <div class="entity-meta-grid">
        <article class="content-card entity-card">
          <p class="content-card__meta">نوع المقال</p>
          <h3>أصلي أو خارجي</h3>
          <p>يمكن تمييز المقالات الأصلية عن المقالات المرتبطة بمنصات نشر خارجية.</p>
        </article>
        <article class="content-card entity-card">
          <p class="content-card__meta">تنظيم داخلي</p>
          <h3>سلسلة وتصنيف</h3>
          <p>كل بطاقة يمكن ربطها بسلسلة علمية أو بتصنيف موضوعي واضح.</p>
        </article>
        <article class="content-card entity-card">
          <p class="content-card__meta">تجربة القراءة</p>
          <h3>زمن ومصدر</h3>
          <p>تظهر بيانات مختصرة مثل زمن القراءة والمصدر حين تكون متوفرة.</p>
        </article>
      </div>
    </section>

    <section class="shell section">
      {featuredSeries.length > 0 && (
        <div class="section-heading">
          <p class="section-kicker">سلاسل بارزة</p>
          <h2 class="section-title">سلاسل منظمة داخل الأرشيف</h2>
          <p class="section-copy">
            أصبح قسم المقالات لا يضم موادًا مفردة فقط، بل يضم أيضًا سلاسل مرتبة يمكن
            متابعتها من خلال فهرس مستقل لكل سلسلة.
          </p>
        </div>
      )}

      {featuredSeries.length > 0 && (
        <div class="grid-two">
          {featuredSeries.map((series) => (
            <a class="card-link" href={getArticleSeriesPath('ar', series.slug)}>
              <article class="content-card entity-card">
                <p class="content-card__meta">سلسلة مقالية | {series.count} مادة</p>
                <h3>{series.title}</h3>
                <p>الانتقال إلى صفحة السلسلة لمتابعة موادها مرتبة داخل الأرشيف.</p>
              </article>
            </a>
          ))}
        </div>
      )}
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">أحدث المواد</p>
        <h2 class="section-title">مقالات منشورة داخل الأرشيف</h2>
      </div>

      <div class="grid-two">
        {articles.map((article) => (
          <a class="card-link" href={getEntryPath('articles', 'ar', article.slug)}>
            <article class="content-card entity-card">
              <p class="content-card__meta">
                {[article.data.category, article.data.date].filter(Boolean).join(' | ')}
              </p>
              <h3>{article.data.title}</h3>
              <p>{article.data.summary}</p>
              <p class="content-card__meta">
                {[article.data.series, article.data.articleType, article.data.readingTime].filter(Boolean).join(' | ')}
              </p>
            </article>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
