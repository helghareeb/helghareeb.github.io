---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import { getEntryPath } from '../../../utils/content-routing';

const books = (await getCollection('books'))
  .filter((entry) => entry.data.lang === 'ar')
  .slice(0, 6);
---

<BaseLayout
  lang="ar"
  dir="rtl"
  title="الكتب | د. هيثم الغريب"
  description="قسم الكتب والمؤلفات ضمن الموقع الشخصي العلمي"
>
  <main class="page-main">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">الكتب</p>
      <h1 class="hero__title">قسم المؤلفات والكتب المنشورة</h1>
      <p class="hero__lead">
        يجمع هذا القسم المؤلفات المنشورة وما يتصل بها من بيانات تعريفية وروابط وملاحظات
        ببليوجرافية مختصرة، مع إمكان التوسع لاحقًا إلى صفحات مستقلة لكل عمل.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">كتب ومؤلفات</span>
        <span class="hero__badge">بيانات ببليوجرافية</span>
        <span class="hero__badge">صفحات مستقلة لاحقًا</span>
      </div>
    </section>

    <section class="shell entity-grid">
      <article class="entity-summary">
        <p class="entity-kicker">وصف القسم</p>
        <h2 class="section-title">مساحة ببليوجرافية قابلة للنمو</h2>
        <p class="section-copy">
          هذه الصفحة مهيأة لعرض الكتب بصيغة منظمة تسمح لاحقًا بظهور كل عنوان مع وصفه،
          وبيانات نشره، وروابطه، ثم الانتقال في مرحلة لاحقة إلى صفحة مستقلة لكل كتاب.
        </p>

        <ul class="entity-tags">
          <li>عناوين معتمدة</li>
          <li>وصف مختصر</li>
          <li>بيانات نشر</li>
          <li>روابط خارجية</li>
        </ul>
      </article>

      <article class="entity-panel">
        <p class="entity-kicker">جاهزية القالب</p>
        <ul class="entity-list">
          <li><strong>الصيغة الحالية:</strong> بطاقات عرض أولية جاهزة للتغذية بالبيانات.</li>
          <li><strong>الخطوة اللاحقة:</strong> إضافة سنة النشر والناشر وروابط العمل عند التوفر.</li>
          <li><strong>الفائدة:</strong> إمكان البناء على نفس القالب دون إعادة تصميم لاحقًا.</li>
        </ul>
      </article>
    </section>

    <section class="shell section">
      <div class="entity-meta-grid">
        <article class="content-card entity-card">
          <p class="content-card__meta">نوع البيانات</p>
          <h3>تعريف بالكتاب</h3>
          <p>العنوان الكامل، وملخص وجيز، وما يحدد موقع العمل داخل المسار العلمي العام.</p>
        </article>
        <article class="content-card entity-card">
          <p class="content-card__meta">بيانات النشر</p>
          <h3>معلومة مرجعية واضحة</h3>
          <p>سنة الإصدار، الجهة الناشرة، أو أي بيانات ببليوجرافية نافعة للقارئ والباحث.</p>
        </article>
        <article class="content-card entity-card">
          <p class="content-card__meta">صلة رقمية</p>
          <h3>روابط وإحالات</h3>
          <p>رابط خارجي، صفحة بيع، أو موضع ظهور العمل في منصات أخرى عند الحاجة.</p>
        </article>
      </div>
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">نماذج أولية</p>
        <h2 class="section-title">مدخلات أولية قابلة للتعديل</h2>
      </div>

      <div class="grid-two">
        {books.map((book) => (
          <a class="card-link" href={getEntryPath('books', 'ar', book.slug)}>
            <article class="content-card entity-card">
              <p class="content-card__meta">{book.data.status ?? 'مسودة أولية'}</p>
              <h3>{book.data.title}</h3>
              <p>{book.data.summary}</p>
              <p class="content-card__meta">{[book.data.workType, book.data.year].filter(Boolean).join(' | ')}</p>
            </article>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
