---
import { getCollection, render } from 'astro:content';
import EntityEntryPage from '../../../components/EntityEntryPage.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import { getEntryRouteSlug } from '../../../utils/content-routing';

export async function getStaticPaths() {
  const entries = (await getCollection('editions')).filter((entry) => entry.data.lang === 'ar');

  return entries.map((entry) => ({
    params: { slug: getEntryRouteSlug(entry.slug) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout lang="ar" dir="rtl" title={`${entry.data.title} | التحقيقات`} description={entry.data.summary}>
  <EntityEntryPage
    lang="ar"
    eyebrow="تحقيق"
    title={entry.data.title}
    summary={entry.data.summary}
    badges={['صفحة تحقيق', 'وصف علمي', entry.data.status ?? 'بيانات أولية']}
    metaItems={[
      { label: 'القسم', value: 'التحقيقات' },
      { label: 'الحالة', value: entry.data.status ?? 'غير محددة' },
      ...(entry.data.workType ? [{ label: 'نوع العمل', value: entry.data.workType }] : []),
      ...(entry.data.sourceType ? [{ label: 'نوع المصدر', value: entry.data.sourceType }] : []),
      ...(entry.data.year ? [{ label: 'السنة', value: entry.data.year }] : []),
    ]}
    backHref="/ar/editions/"
    backLabel="العودة إلى قسم التحقيقات"
    externalUrl={entry.data.externalUrl}
    externalLabel="رابط العمل"
  >
    <Content />
  </EntityEntryPage>
</BaseLayout>
