---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import { getEntryPath } from '../../../utils/content-routing';
import { buildSeoDescription, buildSeoTitle } from '../../../utils/seo';

const editions = (await getCollection('editions'))
  .filter((entry) => entry.data.lang === 'ar')
  .slice(0, 6);
const seoTitle = buildSeoTitle('أعمال التحقيق العلمي والمخطوطات', {
  lang: 'ar',
  section: 'التحقيقات',
});
const seoDescription = buildSeoDescription(
  'أرشيف التحقيقات العربي الذي يجمع أعمال التحقيق العلمي والمخطوطات وبياناتها الأساسية.',
  [
    `${editions.length} أعمال ظاهرة`,
    editions[0]?.data.year ? `أحدث سنة ظاهرة ${editions[0].data.year}` : undefined,
  ],
);
---

<BaseLayout
  lang="ar"
  dir="rtl"
  title={seoTitle}
  description={seoDescription}
>
  <main class="page-main">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">التحقيقات</p>
      <h1 class="hero__title">أعمال التحقيق العلمي والمخطوطات</h1>
      <p class="hero__lead">
        يبرز هذا القسم جانب التحقيق العلمي بوصفه مسارًا مستقلًا داخل الموقع، ويضم الأعمال
        المنشورة أو الجاري الاشتغال عليها، مع بيانات علمية موجزة لكل عمل.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">تحقيقات ومخطوطات</span>
        <span class="hero__badge">حالة العمل</span>
        <span class="hero__badge">وصف علمي مختصر</span>
      </div>
    </section>

    <section class="shell entity-grid">
      <article class="entity-summary">
        <p class="entity-kicker">هوية القسم</p>
        <h2 class="section-title">مسار مستقل داخل المشروع العلمي</h2>
        <p class="section-copy">
          يُعامل هذا القسم بوصفه مسارًا مستقلًا عن الكتب العامة والمقالات، بحيث يظهر فيه
          كل عمل تحقيق بعنوانه، ووصفه العلمي، وحالته، وما يتصل به من روابط أو ملاحظات.
        </p>

        <ul class="entity-tags">
          <li>عنوان التحقيق</li>
          <li>حالة العمل</li>
          <li>وصف علمي</li>
          <li>روابط مرجعية</li>
        </ul>
      </article>

      <article class="entity-panel">
        <p class="entity-kicker">صيغة العرض</p>
        <ul class="entity-list">
          <li><strong>المنشور:</strong> يظهر مع بيانات النشر والإشارة إلى طبيعة العمل.</li>
          <li><strong>قيد الإنجاز:</strong> يظهر مع مرحلة التقدم أو الحالة العامة.</li>
          <li><strong>صلة القسم:</strong> ربط التحقيقات بالمخطوطات والمقالات ذات الصلة.</li>
        </ul>
      </article>
    </section>

    <section class="shell section">
      <div class="entity-meta-grid">
        <article class="content-card entity-card">
          <p class="content-card__meta">البعد العلمي</p>
          <h3>وصف موجز للعمل</h3>
          <p>توضيح قيمة التحقيق أو موضوع المخطوط بلغة مختصرة ومحكمة.</p>
        </article>
        <article class="content-card entity-card">
          <p class="content-card__meta">مرحلة الإنجاز</p>
          <h3>منشور أو قيد الإعداد</h3>
          <p>تمييز الحالة الحالية لكل عمل حتى يفهم الزائر ما تم إنجازه بالفعل.</p>
        </article>
        <article class="content-card entity-card">
          <p class="content-card__meta">صلة بالأقسام</p>
          <h3>ارتباط بالمخطوطات</h3>
          <p>إحالات إلى قسم المخطوطات أو المقالات ذات الصلة المنهجية عند وجودها.</p>
        </article>
      </div>
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">أعمال مدرجة</p>
        <h2 class="section-title">نماذج من التحقيقات الظاهرة</h2>
      </div>

      <div class="grid-two">
        {editions.map((edition) => (
          <a class="card-link" href={getEntryPath('editions', 'ar', edition.slug)}>
            <article class="content-card entity-card">
              <p class="content-card__meta">{edition.data.status ?? 'بيانات متاحة'}</p>
              <h3>{edition.data.title}</h3>
              <p>{edition.data.summary}</p>
              <p class="content-card__meta">{[edition.data.workType, edition.data.year].filter(Boolean).join(' | ')}</p>
            </article>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
