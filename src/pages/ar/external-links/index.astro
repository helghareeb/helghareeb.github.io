---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import { getEntryPath } from '../../../utils/content-routing';

const links = (await getCollection('externalLinks')).filter((entry) => entry.data.lang === 'ar').slice(0, 6);
---

<BaseLayout
  lang="ar"
  dir="rtl"
  title="الروابط الخارجية | د. هيثم الغريب"
  description="قسم الروابط التعليمية والخارجية المرتبطة بالأعمال والمنشورات"
>
  <main class="page-main">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">الروابط الخارجية</p>
      <h1 class="hero__title">روابط تعليمية ومهنية وأعمال منشورة خارج الموقع</h1>
      <p class="hero__lead">
        أُنشئ هذا القسم ليجمع الروابط التعليمية المفيدة، والروابط المهنية والأكاديمية،
        والصفحات الخارجية التي نُشرت فيها كتب أو مقالات أو مواد ذات صلة بالمشروع العلمي.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">روابط موصوفة</span>
        <span class="hero__badge">روابط مهنية وتعليمية</span>
        <span class="hero__badge">وصول إلى نشر خارجي</span>
      </div>
    </section>

    <section class="shell entity-grid">
      <article class="entity-summary">
        <p class="entity-kicker">طبيعة القسم</p>
        <h2 class="section-title">روابط موثقة لا مجرد قائمة خام</h2>
        <p class="section-copy">
          صُمم هذا القسم ليجمع الروابط الخارجية مع وصف موجز ونوع الرابط والجهة المرتبطة به،
          بحيث تكون الروابط مفهومة ومفيدة داخل سياق الموقع لا معزولة عنه.
        </p>
        <ul class="entity-tags">
          <li>تصنيف الرابط</li>
          <li>نوعه</li>
          <li>الجهة</li>
          <li>الرابط الخارجي</li>
        </ul>
      </article>

      <article class="entity-panel">
        <p class="entity-kicker">استعمالات القسم</p>
        <ul class="entity-list">
          <li><strong>روابط تعليمية:</strong> مواد نافعة أو مراجع أو منصات ذات صلة.</li>
          <li><strong>روابط مهنية:</strong> ملفات شخصية أو حضور أكاديمي خارجي.</li>
          <li><strong>روابط نشر:</strong> نقاط وصول إلى أعمال منشورة خارج الموقع.</li>
        </ul>
      </article>
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">نماذج أولية</p>
        <h2 class="section-title">روابط مهيأة للتوسعة</h2>
      </div>

      <div class="grid-two">
        {links.map((link) => (
          <a class="card-link" href={getEntryPath('externalLinks', 'ar', link.slug)}>
            <article class="content-card entity-card">
              <p class="content-card__meta">{[link.data.category, link.data.linkType].filter(Boolean).join(' | ')}</p>
              <h3>{link.data.title}</h3>
              <p>{link.data.summary}</p>
              <p class="content-card__meta">{link.data.sourceName}</p>
            </article>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
