---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import '../../../../styles/global.css';
import { buildSeoDescription, buildSeoTitle } from '../../../../utils/seo';

const seoTitle = buildSeoTitle('الدفاع عن السنة والشبهات', {
  lang: 'ar',
  section: 'المجالات العلمية',
});
const seoDescription = buildSeoDescription(
  'قسم متخصص للردود العلمية والسلاسل المرتبطة بالدفاع عن السنة ومعالجة الشبهات بمنهج واضح.',
  ['سلاسل وردود علمية', 'قسم تخصصي'],
);
---

<BaseLayout
  lang="ar"
  dir="rtl"
  title={seoTitle}
  description={seoDescription}
>
  <main class="page-main page-main--detail">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">الدفاع عن السنة والشبهات</p>
      <h1 class="hero__title">قسم للمعالجة العلمية المنهجية</h1>
      <p class="hero__lead">
        يجمع هذا القسم المواد التي تتناول الشبهات، والردود، والسلاسل
        العلمية المرتبطة بالدفاع عن السنة بمنهج واضح وحجج مرتبة.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">قسم تخصصي</span>
        <span class="hero__badge">سلاسل وردود علمية</span>
      </div>
    </section>

    <section class="shell notice-card">
      <h2 class="section-title">مواد هذا المسار</h2>
      <p>
        مقالات مستقلة، وسلاسل مترابطة، وتصنيفات موضوعية تساعد الزائر على تتبع المسائل
        والاعتراضات والردود ضمن هيكل واضح سهل الرجوع إليه.
      </p>
    </section>
  </main>
</BaseLayout>
