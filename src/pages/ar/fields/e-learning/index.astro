---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import '../../../../styles/global.css';
import { buildSeoDescription, buildSeoTitle } from '../../../../utils/seo';

const seoTitle = buildSeoTitle('التعليم الإلكتروني للعلوم الإسلامية', {
  lang: 'ar',
  section: 'المجالات العلمية',
});
const seoDescription = buildSeoDescription(
  'قسم يعرض المبادرات والرؤى المتعلقة بالتعليم الإلكتروني للعلوم الإسلامية والوسائط والمنهجيات الرقمية.',
  ['تعليم رقمي', 'وسائط ومنهج'],
);
---

<BaseLayout
  lang="ar"
  dir="rtl"
  title={seoTitle}
  description={seoDescription}
>
  <main class="page-main page-main--detail">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">التعليم الإلكتروني للعلوم الإسلامية</p>
      <h1 class="hero__title">التعليم الشرعي في بيئة رقمية منظمة</h1>
      <p class="hero__lead">
        يعرض هذا القسم المبادرات والرؤى التي تربط التعليم الإسلامي بالبناء الرقمي،
        وطرائق العرض، وتنظيم المعرفة، والانتفاع بالوسائط التعليمية الحديثة.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">تعليم رقمي</span>
        <span class="hero__badge">وسائط ومنهج</span>
      </div>
    </section>

    <section class="shell notice-card">
      <h2 class="section-title">اتجاهات هذا المسار</h2>
      <p>
        يضم هذا المسار المواد المرتبطة بالمقررات، والتجارب التعليمية، والمقالات التي تناقش
        البناء الإلكتروني للمعرفة في العلوم الإسلامية.
      </p>
    </section>
  </main>
</BaseLayout>
