---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { getArticleSeriesPath, getEntryPath } from '../../utils/content-routing';

const featuredBooks = (await getCollection('books'))
  .filter((entry) => entry.data.lang === 'ar')
  .slice(0, 2);

const featuredEditions = (await getCollection('editions'))
  .filter((entry) => entry.data.lang === 'ar')
  .slice(0, 2);

const featuredArticles = (await getCollection('articles'))
  .filter((entry) => entry.data.lang === 'ar' && !entry.data.draft)
  .sort((a, b) => {
    const aTime = a.data.date ? new Date(a.data.date).getTime() : 0;
    const bTime = b.data.date ? new Date(b.data.date).getTime() : 0;

    return bTime - aTime;
  })
  .slice(0, 3);

const articleSeriesMap = new Map<
  string,
  {
    title: string;
    slug: string;
    count: number;
    latestDate?: string;
  }
>();

for (const article of await getCollection('articles')) {
  if (article.data.lang !== 'ar' || article.data.draft || !article.data.series || !article.data.seriesSlug) continue;

  const existing = articleSeriesMap.get(article.data.seriesSlug);

  if (existing) {
    existing.count += 1;

    const existingTime = existing.latestDate ? new Date(existing.latestDate).getTime() : 0;
    const articleTime = article.data.date ? new Date(article.data.date).getTime() : 0;

    if (articleTime >= existingTime) {
      existing.latestDate = article.data.date;
    }
  } else {
    articleSeriesMap.set(article.data.seriesSlug, {
      title: article.data.series,
      slug: article.data.seriesSlug,
      count: 1,
      latestDate: article.data.date,
    });
  }
}

const featuredSeries = Array.from(articleSeriesMap.values())
  .sort((a, b) => {
    const aTime = a.latestDate ? new Date(a.latestDate).getTime() : 0;
    const bTime = b.latestDate ? new Date(b.latestDate).getTime() : 0;

    return bTime - aTime;
  })
  .slice(0, 2);

const featuredProjects = (await getCollection('projects'))
  .filter((entry) => entry.data.lang === 'ar')
  .slice(0, 2);

const featuredFields = (await getCollection('fields'))
  .filter((entry) => entry.data.lang === 'ar' && entry.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const featuredMedia = (await getCollection('media'))
  .filter((entry) => entry.data.lang === 'ar')
  .slice(0, 1);

const featuredLinks = (await getCollection('externalLinks'))
  .filter((entry) => entry.data.lang === 'ar' && entry.data.featured)
  .slice(0, 3);
---

<BaseLayout
  lang="ar"
  dir="rtl"
  title="الموقع الشخصي العلمي | د. هيثم الغريب"
  description="الواجهة العربية للموقع الشخصي العلمي للدكتور هيثم الغريب"
>
  <main class="page-main page-main--home">
    <section class="shell hero hero--home">
      <p class="hero__eyebrow">الواجهة العربية</p>
      <h1 class="hero__title">الموقع الشخصي العلمي للدكتور هيثم الغريب</h1>
      <p class="hero__lead">
        موقع علمي شخصي ثنائي اللغة يهدف إلى عرض السيرة العلمية، والكتب، والتحقيقات،
        والمقالات، ومسارات العمل الأكاديمي والمعرفي في صورة حديثة واضحة ومنظمة.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">واجهة عربية أساسية</span>
        <span class="hero__badge">بنية ثنائية اللغة</span>
        <span class="hero__badge">قابلة للتوسع المنظم</span>
      </div>

      <div class="hero__actions">
        <a class="button" href="/ar/cv/">السيرة الذاتية</a>
        <a class="button-secondary" href="/ar/books/">الكتب</a>
        <a class="button-secondary" href="/ar/editions/">التحقيقات</a>
        <a class="button-secondary" href="/ar/articles/">المقالات</a>
      </div>

      <div class="grid-three hero__stats">
        <article class="stat-card">
          <strong>ثنائي اللغة</strong>
          <span>بنية عربية وإنجليزية داخل مستودع واحد.</span>
        </article>
        <article class="stat-card">
          <strong>أقسام أساسية</strong>
          <span>أقسام رئيسية ومجالات علمية ومشروعات وروابط ووسائط.</span>
        </article>
        <article class="stat-card">
          <strong>بنية قابلة للتوسع</strong>
          <span>الواجهة الرئيسية تعرض الآن أقسام الموقع الموسعة ومداخله المنظمة.</span>
        </article>
      </div>
    </section>

    <section class="shell section section--soft">
      <div class="section-heading">
        <p class="section-kicker">نبذة موجزة</p>
        <h2 class="section-title">هوية علمية تجمع بين البحث والتنظيم الرقمي</h2>
        <p class="section-copy">
          تم إعداد هذه النسخة لتكون أساسًا منظمًا لموقع علمي حديث يعرض الأعمال والاهتمامات
          البحثية بصورة رصينة، مع عناية خاصة بالكتب، والتحقيق العلمي، والدراسات الإسلامية،
          والمجالات المتصلة بالمحتوى العلمي الرقمي.
        </p>
      </div>
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">بوابة الموقع</p>
        <h2 class="section-title">المسارات الكبرى في النسخة الحالية</h2>
        <p class="section-copy">
          قبل إدخال المحتوى التفصيلي، صارت البنية الحالية أوضح في عرض المسارات الرئيسة التي
          سيتوسع عبرها الموقع خلال المراحل القادمة.
        </p>
      </div>

      <div class="grid-three">
        {featuredFields.map((field) => (
          <a class="card-link" href={field.data.href}>
            <article class="feature-card feature-card--field">
              <h3>{field.data.title}</h3>
              <p>{field.data.summary}</p>
            </article>
          </a>
        ))}
      </div>
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">الكتب</p>
        <h2 class="section-title">نماذج من المؤلفات</h2>
      </div>

      <div class="grid-two">
        {featuredBooks.map((book) => (
          <article class="content-card">
            <p class="content-card__meta">{book.data.status ?? 'بيانات أولية'}</p>
            <h3>{book.data.title}</h3>
            <p>{book.data.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">التحقيقات</p>
        <h2 class="section-title">نماذج من أعمال التحقيق</h2>
      </div>

      <div class="grid-two">
        {featuredEditions.map((edition) => (
          <article class="content-card">
            <p class="content-card__meta">{edition.data.status ?? 'بيانات أولية'}</p>
            <h3>{edition.data.title}</h3>
            <p>{edition.data.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">المشروعات والوسائط والروابط</p>
        <h2 class="section-title">مسارات جاهزة للتفعيل التدريجي</h2>
      </div>

      <div class="grid-three">
        {featuredProjects.map((project) => (
          <article class="content-card">
            <p class="content-card__meta">{project.data.status ?? 'قيد التنظيم'}</p>
            <h3>{project.data.title}</h3>
            <p>{project.data.summary}</p>
          </article>
        ))}
        {featuredMedia.map((item) => (
          <article class="content-card">
            <p class="content-card__meta">{item.data.type ?? 'وسائط'}</p>
            <h3>{item.data.title}</h3>
            <p>{item.data.summary}</p>
          </article>
        ))}
        {featuredLinks.map((link) => (
          <a class="card-link" href={getEntryPath('externalLinks', 'ar', link.slug)}>
            <article class="content-card">
              <p class="content-card__meta">{link.data.category ?? 'روابط خارجية'}</p>
              <h3>{link.data.title}</h3>
              <p>{link.data.summary}</p>
            </article>
          </a>
        ))}
      </div>
    </section>

    <section class="shell section">
      {featuredSeries.length > 0 && (
        <div class="section-heading">
          <p class="section-kicker">سلاسل بارزة</p>
          <h2 class="section-title">سلاسل مقالية نشطة داخل الأرشيف</h2>
          <p class="section-copy">
            لم يعد قسم المقالات يقتصر على المواد المفردة، بل صار يضم سلاسل كاملة
            منظَّمة داخل الموقع مع صفحات مستقلة لكل سلسلة.
          </p>
        </div>
      )}

      {featuredSeries.length > 0 && (
        <div class="grid-two">
          {featuredSeries.map((series) => (
            <article class="cta-panel">
              <div>
                <p class="section-kicker">ضمن قسم المقالات</p>
                <h2 class="section-title">{series.title}</h2>
                <p class="section-copy">
                  تحتوي هذه السلسلة الآن على {series.count} مادة مرتبة، ويمكن الدخول إليها
                  من فهرس مستقل داخل الموقع.
                </p>
              </div>
              <div class="hero__actions">
                <a class="button" href={getArticleSeriesPath('ar', series.slug)}>عرض السلسلة</a>
                <a class="button-secondary" href="/ar/articles/">قسم المقالات</a>
              </div>
            </article>
          ))}
        </div>
      )}
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">المقالات</p>
        <h2 class="section-title">أحدث المداخل المقالية</h2>
      </div>

      <div class="grid-three">
        {featuredArticles.map((article) => (
          <article class="content-card">
            <p class="content-card__meta">
              {[article.data.category, article.data.date].filter(Boolean).join(' | ')}
            </p>
            <h3>{article.data.title}</h3>
            <p>{article.data.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="shell cta-panel">
      <div>
        <p class="section-kicker">جاهزية تنظيمية</p>
        <h2 class="section-title">الموقع مهيأ الآن للتوسع المنظم</h2>
        <p class="section-copy">
          صار بالإمكان متابعة العمل لاحقًا عبر إدخال المحتوى المعتمد أو تطوير البوابات
          الحالية دون الحاجة إلى إعادة ترتيب الهيكل من جديد.
        </p>
      </div>
      <div class="hero__actions">
        <a class="button" href="/ar/fields/">المجالات العلمية</a>
        <a class="button-secondary" href="/ar/projects/">المشروعات</a>
        <a class="button-secondary" href="/ar/learning-path/">المسار التعليمي</a>
      </div>
    </section>
  </main>
</BaseLayout>
