---
import { getCollection, render } from 'astro:content';
import EntityEntryPage from '../../../components/EntityEntryPage.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import { getEntryRouteSlug } from '../../../utils/content-routing';
import { buildSeoDescription, buildSeoTitle } from '../../../utils/seo';

export async function getStaticPaths() {
  const entries = (await getCollection('projects')).filter((entry) => entry.data.lang === 'ar');

  return entries.map((entry) => ({
    params: { slug: getEntryRouteSlug(entry.slug) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const seoTitle = buildSeoTitle(entry.data.title, { lang: 'ar', section: 'المشروعات' });
const seoDescription = buildSeoDescription(entry.data.summary, [
  entry.data.area,
  entry.data.status,
  entry.data.startYear ? `بدأ في ${entry.data.startYear}` : undefined,
]);
---

<BaseLayout lang="ar" dir="rtl" title={seoTitle} description={seoDescription}>
  <EntityEntryPage
    lang="ar"
    eyebrow="مشروع"
    title={entry.data.title}
    summary={entry.data.summary}
    badges={['صفحة مشروع', 'وحدة مستقلة', entry.data.status ?? 'بيانات أولية']}
    metaItems={[
      { label: 'القسم', value: 'المشروعات' },
      { label: 'الحالة', value: entry.data.status ?? 'غير محددة' },
      ...(entry.data.area ? [{ label: 'المجال', value: entry.data.area }] : []),
      ...(entry.data.startYear ? [{ label: 'سنة البدء', value: entry.data.startYear }] : []),
    ]}
    backHref="/ar/projects/"
    backLabel="العودة إلى قسم المشروعات"
    externalUrl={entry.data.externalUrl}
    externalLabel="رابط المشروع"
  >
    <Content />
  </EntityEntryPage>
</BaseLayout>
