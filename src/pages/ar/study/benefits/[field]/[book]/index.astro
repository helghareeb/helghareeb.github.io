---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../../../../layouts/BaseLayout.astro';
import '../../../../../../styles/global.css';
import { buildSeoDescription, buildSeoTitle } from '../../../../../../utils/seo';
import { getEntryPath } from '../../../../../../utils/content-routing';
import { getStudyBenefitRouteSlug } from '../../../../../../utils/study';

export async function getStaticPaths() {
  const entries = (await getCollection('studyBenefits')).filter((entry) => entry.data.lang === 'ar' && !entry.data.draft);
  const groups = new Map<string, CollectionEntry<'studyBenefits'>[]>();

  for (const entry of entries) {
    const key = `${entry.data.fieldSlug}::${entry.data.bookSlug}`;
    groups.set(key, [...(groups.get(key) ?? []), entry]);
  }

  return Array.from(groups.entries()).map(([key, groupedEntries]) => {
    const [field, book] = key.split('::');

    return {
      params: { field, book },
      props: { entries: groupedEntries.sort((a, b) => a.data.title.localeCompare(b.data.title, 'ar')) },
    };
  });
}

const { entries } = Astro.props as { entries: CollectionEntry<'studyBenefits'>[] };
const referenceEntry = entries[0];
const seoTitle = buildSeoTitle(referenceEntry.data.bookTitle, {
  lang: 'ar',
  section: 'فوائد من كتب متنوعة',
});
const seoDescription = buildSeoDescription(
  `دفتر فوائد منظم تحت كتاب ${referenceEntry.data.bookTitle} ضمن قسم مذاكرة طالب العلم.`,
  [referenceEntry.data.field, referenceEntry.data.teacher, `${entries.length} دفاتر منشورة`],
);
---

<BaseLayout lang="ar" dir="rtl" title={seoTitle} description={seoDescription}>
  <main class="page-main">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">فوائد من كتب متنوعة</p>
      <h1 class="hero__title">{referenceEntry.data.bookTitle}</h1>
      <p class="hero__lead">
        هذه الصفحة تجمع دفاتر الفوائد المنشورة لهذا الكتاب داخل الموقع، مع إبراز الفن
        والشرح والموضوعات التي جرى ترتيبها لخدمة المراجعة العلمية.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">{referenceEntry.data.field}</span>
        {referenceEntry.data.teacher && <span class="hero__badge">{referenceEntry.data.teacher}</span>}
        <span class="hero__badge">{entries.length} دفاتر فوائد</span>
      </div>
    </section>

    <section class="shell notice-card">
      <h2 class="section-title">تنبيه تحريري</h2>
      <p>
        هذه الفوائد مرتبة ومنشورة داخل الموقع لخدمة الطالب، مع التأكيد أن الشيخ لم يطّلع
        على هذه الصياغة المنشورة هنا.
      </p>
    </section>

    <section class="shell section">
      <div class="grid-two">
        {entries.map((entry) => (
          <a class="card-link" href={getEntryPath('studyBenefits', 'ar', getStudyBenefitRouteSlug(entry.slug))}>
            <article class="content-card entity-card">
              <p class="content-card__meta">{entry.data.field}</p>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.summary}</p>
            </article>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
