---
import { getCollection, render } from 'astro:content';
import EntityEntryPage from '../../../components/EntityEntryPage.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import { getEntryRouteSlug } from '../../../utils/content-routing';

export async function getStaticPaths() {
  const entries = (await getCollection('articles')).filter((entry) => entry.data.lang === 'en' && !entry.data.draft);

  return entries.map((entry) => ({
    params: { slug: getEntryRouteSlug(entry.slug) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout lang="en" dir="ltr" title={`${entry.data.title} | Articles`} description={entry.data.summary}>
  <EntityEntryPage
    lang="en"
    eyebrow="Article"
    title={entry.data.title}
    summary={entry.data.summary}
    badges={['Article page', entry.data.articleType ?? 'Article', entry.data.category ?? 'General category']}
    metaItems={[
      { label: 'Section', value: 'Articles' },
      ...(entry.data.date ? [{ label: 'Date', value: entry.data.date }] : []),
      ...(entry.data.series ? [{ label: 'Series', value: entry.data.series }] : []),
      ...(entry.data.sourceName ? [{ label: 'Source', value: entry.data.sourceName }] : []),
      ...(entry.data.readingTime ? [{ label: 'Reading time', value: entry.data.readingTime }] : []),
    ]}
    backHref="/en/articles/"
    backLabel="Back to articles"
    externalUrl={entry.data.externalUrl}
    externalLabel="Article link"
  >
    <Content />

    {entry.data.sourceName && entry.data.externalUrl && (
      <section class="notice-card">
        <p class="entity-kicker">Original publication</p>
        <h2 class="section-title">This article is also published on {entry.data.sourceName}</h2>
        <p>
          This page presents an organized in-site version of the article within the website archive,
          while the original publication remains available on {entry.data.sourceName}.
        </p>
        <p>
          <a href={entry.data.externalUrl}>Go to the article on {entry.data.sourceName}</a>
        </p>
      </section>
    )}
  </EntityEntryPage>
</BaseLayout>
