---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import { getArticleSeriesPath, getEntryPath } from '../../../utils/content-routing';
import { buildSeoDescription, buildSeoTitle } from '../../../utils/seo';

const allArticles = (await getCollection('articles'))
  .filter((entry) => entry.data.lang === 'en' && !entry.data.draft)
  .sort((a, b) => {
    const aTime = a.data.date ? new Date(a.data.date).getTime() : 0;
    const bTime = b.data.date ? new Date(b.data.date).getTime() : 0;

    return bTime - aTime;
  });

const articles = allArticles.slice(0, 6);

const seriesMap = new Map<
  string,
  {
    title: string;
    slug: string;
    count: number;
  }
>();

for (const article of allArticles) {
  if (!article.data.series || !article.data.seriesSlug) continue;

  const existing = seriesMap.get(article.data.seriesSlug);

  if (existing) {
    existing.count += 1;
  } else {
    seriesMap.set(article.data.seriesSlug, {
      title: article.data.series,
      slug: article.data.seriesSlug,
      count: 1,
    });
  }
}

const featuredSeries = Array.from(seriesMap.values())
  .sort((a, b) => b.count - a.count)
  .slice(0, 3);
const seoTitle = buildSeoTitle('Articles, essays, and thematic series', {
  lang: 'en',
  section: 'Articles',
});
const seoDescription = buildSeoDescription(
  'English articles archive gathering original writing, translated materials, and organized series.',
  [
    `${allArticles.length} published entries`,
    featuredSeries.length ? `${featuredSeries.length} featured series` : undefined,
    articles[0]?.data.date ? `Latest update ${articles[0].data.date}` : undefined,
  ],
);
---

<BaseLayout
  lang="en"
  dir="ltr"
  title={seoTitle}
  description={seoDescription}
>
  <main class="page-main">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">Articles</p>
      <h1 class="hero__title">Articles, essays, and thematic series</h1>
      <p class="hero__lead">
        This section serves as the website's publishing space, gathering original articles,
        selected externally published pieces, and thematic series in a clear archive.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">Original articles</span>
        <span class="hero__badge">Thematic series</span>
        <span class="hero__badge">Structured archive</span>
      </div>
    </section>

    <section class="shell entity-grid">
      <article class="entity-summary">
        <p class="entity-kicker">Purpose</p>
        <h2 class="section-title">A living archive for ongoing publication</h2>
        <p class="section-copy">
          This archive brings together original articles, linked external writing, and thematic
          series with structured metadata that supports both browsing and long-term reference.
        </p>
        <ul class="entity-tags">
          <li>Date</li>
          <li>Category</li>
          <li>Series</li>
          <li>Source</li>
        </ul>
      </article>

      <article class="entity-panel">
        <p class="entity-kicker">Display readiness</p>
        <ul class="entity-list">
          <li><strong>Current state:</strong> article cards and standalone item pages are active.</li>
          <li><strong>Current scope:</strong> entries, series, and source-aware metadata are already in place.</li>
          <li><strong>Goal:</strong> preserve a coherent scholarly archive as the site grows.</li>
        </ul>
      </article>
    </section>

    <section class="shell section">
      <div class="entity-meta-grid">
        <article class="content-card entity-card">
          <p class="content-card__meta">Article type</p>
          <h3>Original or external</h3>
          <p>Entries can distinguish between original site writing and externally linked publication.</p>
        </article>
        <article class="content-card entity-card">
          <p class="content-card__meta">Internal structure</p>
          <h3>Series and category</h3>
          <p>Each item can be tied to a thematic series or an organizing subject category.</p>
        </article>
        <article class="content-card entity-card">
          <p class="content-card__meta">Reading context</p>
          <h3>Time and source</h3>
          <p>Compact metadata can surface reading time and source when those details are available.</p>
        </article>
      </div>
    </section>

    <section class="shell section">
      {featuredSeries.length > 0 && (
        <div class="section-heading">
          <p class="section-kicker">Featured series</p>
          <h2 class="section-title">Structured series inside the archive</h2>
          <p class="section-copy">
            The English archive can now present connected article series through dedicated landing
            pages, not only as isolated entries.
          </p>
        </div>
      )}

      {featuredSeries.length > 0 && (
        <div class="grid-two">
          {featuredSeries.map((series) => (
            <a class="card-link" href={getArticleSeriesPath('en', series.slug)}>
              <article class="content-card entity-card">
                <p class="content-card__meta">Article series | {series.count} entries</p>
                <h3>{series.title}</h3>
                <p>Open the series page to browse its translated entries in order.</p>
              </article>
            </a>
          ))}
        </div>
      )}
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">Latest entries</p>
        <h2 class="section-title">Published articles inside the archive</h2>
      </div>

      {articles.length > 0 ? (
        <div class="grid-two">
          {articles.map((article) => (
            <a class="card-link" href={getEntryPath('articles', 'en', article.slug)}>
              <article class="content-card entity-card">
                <p class="content-card__meta">
                  {[article.data.category, article.data.date].filter(Boolean).join(' | ')}
                </p>
                <h3>{article.data.title}</h3>
                <p>{article.data.summary}</p>
                <p class="content-card__meta">
                  {[article.data.series, article.data.articleType, article.data.readingTime].filter(Boolean).join(' | ')}
                </p>
              </article>
            </a>
          ))}
        </div>
      ) : (
        <article class="notice-card">
          <h2>No English articles are published yet</h2>
          <p>
            This archive will display translated and original English entries automatically as soon
            as article files are added.
          </p>
        </article>
      )}
    </section>
  </main>
</BaseLayout>
