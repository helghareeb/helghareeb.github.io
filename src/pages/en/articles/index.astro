---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
---

<BaseLayout
  lang="en"
  dir="ltr"
  title="Articles | Dr. Haitham A. El-Ghareeb"
  description="Articles section of the personal scholarly website"
>
  <main class="page-main">
    <section class="shell hero">
      <p class="hero__eyebrow">Articles</p>
      <h1 class="hero__title">Articles, essays, and thematic series</h1>
      <p class="hero__lead">
        This route is prepared for article archives, selected published pieces, and future
        thematic series arranged in a structured and navigable format.
      </p>
    </section>

    <section class="shell notice-card">
      <h2 class="section-title">Planned structure</h2>
      <ul class="list-clean">
        <li>Original website articles and essays.</li>
        <li>Selected externally published pieces.</li>
        <li>Series, categories, and topic-based organization.</li>
      </ul>
    </section>
  </main>
</BaseLayout>
