---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import '../../../../styles/global.css';
import { getEntryPath } from '../../../../utils/content-routing';
import { buildSeoDescription, buildSeoTitle } from '../../../../utils/seo';

export async function getStaticPaths() {
  const articles = (await getCollection('articles')).filter(
    (entry) => entry.data.lang === 'en' && !entry.data.draft && entry.data.series && entry.data.seriesSlug,
  );

  const seriesMap = new Map<string, { title: string }>();

  for (const article of articles) {
    const slug = article.data.seriesSlug!;
    if (!seriesMap.has(slug)) {
      seriesMap.set(slug, { title: article.data.series! });
    }
  }

  return Array.from(seriesMap.entries()).map(([series, data]) => ({
    params: { series },
    props: { seriesSlug: series, seriesTitle: data.title },
  }));
}

const { seriesSlug, seriesTitle } = Astro.props;
const seriesArticles = (await getCollection('articles'))
  .filter(
    (entry) =>
      entry.data.lang === 'en' &&
      !entry.data.draft &&
      entry.data.seriesSlug === seriesSlug,
  )
  .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));

const firstArticle = seriesArticles[0];
const lastArticle = seriesArticles[seriesArticles.length - 1];
const seoTitle = buildSeoTitle(seriesTitle, { lang: 'en', section: 'Article Series' });
const seoDescription = buildSeoDescription(
  `Series index for ${seriesTitle} inside the English articles archive.`,
  [
    `${seriesArticles.length} entries`,
    firstArticle?.data.category,
    lastArticle?.data.date ? `Latest entry ${lastArticle.data.date}` : undefined,
  ],
);
---

<BaseLayout
  lang="en"
  dir="ltr"
  title={seoTitle}
  description={seoDescription}
>
  <main class="page-main">
    <section class="shell hero hero--portal">
      <p class="hero__eyebrow">Article Series</p>
      <h1 class="hero__title">{seriesTitle}</h1>
      <p class="hero__lead">
        A dedicated index for navigating this series in sequence within the English archive.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">{seriesArticles.length} entries</span>
        {firstArticle?.data.date && <span class="hero__badge">First: {firstArticle.data.date}</span>}
        {lastArticle?.data.date && <span class="hero__badge">Latest: {lastArticle.data.date}</span>}
      </div>
    </section>

    <section class="shell entity-grid">
      <article class="entity-summary">
        <p class="entity-kicker">Series overview</p>
        <h2 class="section-title">One sequence, separately organized</h2>
        <p class="section-copy">
          These entries are grouped here so the full series can be followed in order, while each
          article still remains accessible through its standalone page in the general archive.
        </p>
      </article>

      <article class="entity-panel">
        <p class="entity-kicker">Quick facts</p>
        <ul class="entity-list">
          <li><strong>Total entries:</strong> {seriesArticles.length}</li>
          {firstArticle?.data.category && <li><strong>Category:</strong> {firstArticle.data.category}</li>}
          {firstArticle?.data.sourceName && <li><strong>Source:</strong> {firstArticle.data.sourceName}</li>}
          <li><strong>Back to:</strong> <a href="/en/articles/">Articles</a></li>
        </ul>
      </article>
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">Series entries</p>
        <h2 class="section-title">Full sequence</h2>
      </div>

      <div class="grid-two">
        {seriesArticles.map((article) => (
          <a class="card-link" href={getEntryPath('articles', 'en', article.slug)}>
            <article class="content-card entity-card">
              <p class="content-card__meta">
                {[article.data.date, article.data.articleType].filter(Boolean).join(' | ')}
              </p>
              <h3>{article.data.title}</h3>
              <p>{article.data.summary}</p>
              <p class="content-card__meta">
                {[article.data.articleType, article.data.readingTime].filter(Boolean).join(' | ')}
              </p>
            </article>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
