---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import '../../../../styles/global.css';
import { getArticleSeriesPath } from '../../../../utils/content-routing';
import { buildSeoDescription, buildSeoTitle } from '../../../../utils/seo';

const articles = (await getCollection('articles')).filter((entry) => entry.data.lang === 'en' && !entry.data.draft && entry.data.series);

const seriesMap = new Map<
  string,
  {
    title: string;
    slug: string;
    count: number;
    latestDate?: string;
    latestTitle?: string;
    category?: string;
  }
>();

for (const article of articles) {
  const slug = article.data.seriesSlug ?? article.slug;
  const existing = seriesMap.get(slug);

  if (!existing) {
    seriesMap.set(slug, {
      title: article.data.series!,
      slug,
      count: 1,
      latestDate: article.data.date,
      latestTitle: article.data.title,
      category: article.data.category,
    });
    continue;
  }

  existing.count += 1;

  const existingTime = existing.latestDate ? new Date(existing.latestDate).getTime() : 0;
  const articleTime = article.data.date ? new Date(article.data.date).getTime() : 0;

  if (articleTime >= existingTime) {
    existing.latestDate = article.data.date;
    existing.latestTitle = article.data.title;
    existing.category = article.data.category;
  }
}

const seriesEntries = Array.from(seriesMap.values()).sort((a, b) => {
  const aTime = a.latestDate ? new Date(a.latestDate).getTime() : 0;
  const bTime = b.latestDate ? new Date(b.latestDate).getTime() : 0;

  return bTime - aTime;
});
const seoTitle = buildSeoTitle('Article series archive', {
  lang: 'en',
  section: 'Article Series',
});
const seoDescription = buildSeoDescription(
  'Index of English article series published inside the site archive.',
  [
    `${seriesEntries.length} series`,
    seriesEntries[0]?.latestDate ? `Latest update ${seriesEntries[0].latestDate}` : undefined,
  ],
);
---

<BaseLayout
  lang="en"
  dir="ltr"
  title={seoTitle}
  description={seoDescription}
>
  <main class="page-main">
    <section class="shell hero hero--portal">
      <p class="hero__eyebrow">Article Series</p>
      <h1 class="hero__title">Thematic series inside the articles archive</h1>
      <p class="hero__lead">
        This page gathers the organized article series published in English, making each series easy
        to browse as a connected sequence rather than isolated entries.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">Unified index</span>
        <span class="hero__badge">Series order</span>
        <span class="hero__badge">Clearer navigation</span>
      </div>
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">Available series</p>
        <h2 class="section-title">Current English series records</h2>
      </div>

      {seriesEntries.length > 0 ? (
        <div class="grid-two">
          {seriesEntries.map((series) => (
            <a class="card-link" href={getArticleSeriesPath('en', series.slug)}>
              <article class="content-card entity-card">
                <p class="content-card__meta">
                  {[series.category, `${series.count} entries`].filter(Boolean).join(' | ')}
                </p>
                <h3>{series.title}</h3>
                <p>
                  {series.latestTitle
                    ? `Latest entry in this series: ${series.latestTitle}`
                    : 'An organized series within the archive.'}
                </p>
                <p class="content-card__meta">{series.latestDate ?? 'No date'}</p>
              </article>
            </a>
          ))}
        </div>
      ) : (
        <article class="notice-card">
          <h2>No English article series are published yet</h2>
          <p>
            This page will list translated or originally English series automatically as they are
            added to the archive.
          </p>
        </article>
      )}
    </section>
  </main>
</BaseLayout>
