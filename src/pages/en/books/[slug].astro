---
import { getCollection, render } from 'astro:content';
import EntityEntryPage from '../../../components/EntityEntryPage.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import { getEntryRouteSlug } from '../../../utils/content-routing';

export async function getStaticPaths() {
  const entries = (await getCollection('books')).filter((entry) => entry.data.lang === 'en');

  return entries.map((entry) => ({
    params: { slug: getEntryRouteSlug(entry.slug) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout lang="en" dir="ltr" title={`${entry.data.title} | Books`} description={entry.data.summary}>
  <EntityEntryPage
    lang="en"
    eyebrow="Book"
    title={entry.data.title}
    summary={entry.data.summary}
    badges={['Book page', 'Standalone entry', entry.data.status ?? 'Available record']}
    metaItems={[
      { label: 'Section', value: 'Books' },
      { label: 'Status', value: entry.data.status ?? 'Unspecified' },
      ...(entry.data.workType ? [{ label: 'Work type', value: entry.data.workType }] : []),
      ...(entry.data.year ? [{ label: 'Year', value: entry.data.year }] : []),
      ...(entry.data.publisher ? [{ label: 'Publisher', value: entry.data.publisher }] : []),
    ]}
    backHref="/en/books/"
    backLabel="Back to books"
    externalUrl={entry.data.externalUrl}
    externalLabel="Work link"
  >
    <Content />
  </EntityEntryPage>
</BaseLayout>
