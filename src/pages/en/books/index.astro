---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import { getEntryPath } from '../../../utils/content-routing';
import { buildSeoDescription, buildSeoTitle } from '../../../utils/seo';

const books = (await getCollection('books'))
  .filter((entry) => entry.data.lang === 'en')
  .sort((a, b) => {
    const yearDiff = Number(b.data.year ?? 0) - Number(a.data.year ?? 0);
    if (yearDiff !== 0) return yearDiff;

    const publishedA = /published/i.test(a.data.status ?? '');
    const publishedB = /published/i.test(b.data.status ?? '');
    if (publishedA !== publishedB) return publishedB ? 1 : -1;

    return a.data.title.localeCompare(b.data.title, 'en');
  })
  .slice(0, 6);
const seoTitle = buildSeoTitle('Authored and published works', {
  lang: 'en',
  section: 'Books',
});
const seoDescription = buildSeoDescription(
  'English books archive for authored works, course books, and publication-ready manuscripts.',
  [
    `${books.length} featured entries`,
    books[0]?.data.year ? `Latest listed year ${books[0].data.year}` : undefined,
  ],
);
---

<BaseLayout
  lang="en"
  dir="ltr"
  title={seoTitle}
  description={seoDescription}
>
  <main class="page-main">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">Books</p>
      <h1 class="hero__title">Authored and published works</h1>
      <p class="hero__lead">
        This section gathers authored books, course books, and publication-ready manuscripts
        that represent the scholarly and academic profile of Dr. Haitham A. El-Ghareeb.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">Books and authored works</span>
        <span class="hero__badge">Bibliographic metadata</span>
        <span class="hero__badge">Direct access links</span>
      </div>
    </section>

    <section class="shell entity-grid">
      <article class="entity-summary">
        <p class="entity-kicker">Section purpose</p>
        <h2 class="section-title">A clearer bibliography-facing archive</h2>
        <p class="section-copy">
          The page presents books in a consistent format that combines title, summary,
          publication context, and outward access links where available.
        </p>

        <ul class="entity-tags">
          <li>Approved titles</li>
          <li>Short summary</li>
          <li>Publication details</li>
          <li>External links</li>
        </ul>
      </article>

      <article class="entity-panel">
        <p class="entity-kicker">Template readiness</p>
        <ul class="entity-list">
          <li><strong>Current form:</strong> compact cards with title, summary, year, and access point.</li>
          <li><strong>Ordering:</strong> newer and more publication-ready entries appear first.</li>
          <li><strong>Long-term use:</strong> the same layout can absorb more titles without redesign.</li>
        </ul>
      </article>
    </section>

    <section class="shell section">
      <div class="entity-meta-grid">
        <article class="content-card entity-card">
          <p class="content-card__meta">Identity</p>
          <h3>What the title is</h3>
          <p>Each entry foregrounds the book's title and role within the wider scholarly profile.</p>
        </article>
        <article class="content-card entity-card">
          <p class="content-card__meta">Publication</p>
          <h3>Clear reference details</h3>
          <p>Publication year, publisher, or other useful bibliographic reference points.</p>
        </article>
        <article class="content-card entity-card">
          <p class="content-card__meta">Access</p>
          <h3>Links and references</h3>
          <p>Space for outward links, listings, or external access points when appropriate.</p>
        </article>
      </div>
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">Current entries</p>
        <h2 class="section-title">Books shown with the latest items first</h2>
      </div>

      <div class="grid-two">
        {books.map((book) => (
          <a class="card-link" href={getEntryPath('books', 'en', book.slug)}>
            <article class="content-card entity-card">
              <p class="content-card__meta">{book.data.status ?? 'Available record'}</p>
              <h3>{book.data.title}</h3>
              <p>{book.data.summary}</p>
              <p class="content-card__meta">{[book.data.workType, book.data.year].filter(Boolean).join(' | ')}</p>
            </article>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
