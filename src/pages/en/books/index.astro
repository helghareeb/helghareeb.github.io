---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
---

<BaseLayout
  lang="en"
  dir="ltr"
  title="Books | Dr. Haitham A. El-Ghareeb"
  description="Books section of the personal scholarly website"
>
  <main class="page-main">
    <section class="shell hero">
      <p class="hero__eyebrow">Books</p>
      <h1 class="hero__title">Authored and published works</h1>
      <p class="hero__lead">
        This section is prepared for books authored and published by Dr. Haitham A. El-Ghareeb,
        with space for descriptions, publication details, and related links.
      </p>
    </section>

    <section class="shell notice-card">
      <h2 class="section-title">This section will include</h2>
      <ul class="list-clean">
        <li>Approved book titles and short descriptions.</li>
        <li>Core publication information.</li>
        <li>External links where relevant.</li>
      </ul>
    </section>
  </main>
</BaseLayout>
