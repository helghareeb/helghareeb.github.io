---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
---

<BaseLayout
  lang="en"
  dir="ltr"
  title="Contact | Dr. Haitham A. El-Ghareeb"
  description="Contact and professional links"
>
  <main class="page-main">
    <section class="shell hero">
      <p class="hero__eyebrow">Contact</p>
      <h1 class="hero__title">Contact and professional presence</h1>
      <p class="hero__lead">
        This page presents the approved contact channels and selected academic or professional
        links intended for public visitors.
      </p>
    </section>

    <section class="shell section">
      <div class="grid-three">
        <article class="feature-card">
          <h3>Professional contact</h3>
          <p>For the preferred public method of scholarly correspondence or inquiries.</p>
        </article>
        <article class="feature-card">
          <h3>Academic links</h3>
          <p>For institutional, professional, or academic profiles connected to the site owner.</p>
        </article>
        <article class="feature-card">
          <h3>Public visibility</h3>
          <p>Only the channels explicitly approved for visitors will be surfaced here.</p>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
