---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
---

<BaseLayout
  lang="en"
  dir="ltr"
  title="Critical Editions | Dr. Haitham A. El-Ghareeb"
  description="Critical editions section of the personal scholarly website"
>
  <main class="page-main">
    <section class="shell hero">
      <p class="hero__eyebrow">Critical Editions</p>
      <h1 class="hero__title">Scholarly editorial work and manuscript-related projects</h1>
      <p class="hero__lead">
        This section is dedicated to published and ongoing critical editions, with room for
        concise scholarly descriptions, status labels, and related references.
      </p>
    </section>

    <section class="shell notice-card">
      <h2 class="section-title">Planned details</h2>
      <ul class="list-clean">
        <li>Edition titles and publication status.</li>
        <li>Short scholarly descriptions for each work.</li>
        <li>Relevant links and related project references.</li>
      </ul>
    </section>
  </main>
</BaseLayout>
