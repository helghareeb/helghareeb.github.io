---
import { getCollection, render } from 'astro:content';
import EntityEntryPage from '../../../components/EntityEntryPage.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import { getEntryRouteSlug } from '../../../utils/content-routing';

export async function getStaticPaths() {
  const entries = (await getCollection('externalLinks')).filter((entry) => entry.data.lang === 'en');

  return entries.map((entry) => ({
    params: { slug: getEntryRouteSlug(entry.slug) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout lang="en" dir="ltr" title={`${entry.data.title} | External Links`} description={entry.data.summary}>
  <EntityEntryPage
    lang="en"
    eyebrow="External Link"
    title={entry.data.title}
    summary={entry.data.summary}
    badges={['Described link', entry.data.linkType ?? 'Link', entry.data.category ?? 'General category']}
    metaItems={[
      { label: 'Section', value: 'External Links' },
      ...(entry.data.sourceName ? [{ label: 'Source', value: entry.data.sourceName }] : []),
      ...(entry.data.linkType ? [{ label: 'Type', value: entry.data.linkType }] : []),
      { label: 'Featured', value: entry.data.featured ? 'Yes' : 'No' },
    ]}
    backHref="/en/external-links/"
    backLabel="Back to external links"
    externalUrl={entry.data.externalUrl}
    externalLabel="Open link"
  >
    <Content />
  </EntityEntryPage>
</BaseLayout>
