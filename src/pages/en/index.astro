---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
---

<BaseLayout
  lang="en"
  dir="ltr"
  title="Dr. Haitham A. El-Ghareeb | Personal Scholarly Website"
  description="English interface of the personal scholarly website of Dr. Haitham A. El-Ghareeb"
>
  <main class="page-main">
    <section class="shell hero">
      <p class="hero__eyebrow">English Interface</p>
      <h1 class="hero__title">Dr. Haitham A. El-Ghareeb</h1>
      <p class="hero__lead">
        A bilingual scholarly website designed to present academic identity, books, critical
        editions, articles, and future research-facing digital sections in a clear and modern structure.
      </p>

      <div class="hero__actions">
        <a class="button" href="/en/cv/">View CV</a>
        <a class="button-secondary" href="/en/books/">Books</a>
        <a class="button-secondary" href="/en/critical-editions/">Critical Editions</a>
        <a class="button-secondary" href="/en/articles/">Articles</a>
      </div>

      <div class="grid-three hero__stats">
        <article class="stat-card">
          <strong>Bilingual</strong>
          <span>Arabic-first structure with a parallel English experience.</span>
        </article>
        <article class="stat-card">
          <strong>Scholarly Focus</strong>
          <span>Academic profile, publications, editions, and structured content growth.</span>
        </article>
        <article class="stat-card">
          <strong>Launch Edition</strong>
          <span>A clean first release prepared for steady expansion.</span>
        </article>
      </div>
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">Overview</p>
        <h2 class="section-title">A structured foundation for a growing scholarly archive</h2>
        <p class="section-copy">
          This edition establishes the core public-facing structure of the website and prepares
          the ground for richer biography, publication records, article archives, and specialized sections.
        </p>
      </div>
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">Core sections</p>
        <h2 class="section-title">What visitors can access now</h2>
      </div>

      <div class="grid-three">
        <article class="feature-card">
          <h3>About</h3>
          <p>An introductory page for the scholarly profile and broader purpose of the site.</p>
        </article>
        <article class="feature-card">
          <h3>CV</h3>
          <p>A dedicated route for academic background, experience, and professional record.</p>
        </article>
        <article class="feature-card">
          <h3>Books</h3>
          <p>A structured section for authored and published books with room for future detail pages.</p>
        </article>
        <article class="feature-card">
          <h3>Critical Editions</h3>
          <p>A distinct section highlighting scholarly editorial work as an independent body of output.</p>
        </article>
        <article class="feature-card">
          <h3>Articles</h3>
          <p>A route prepared for essays, research notes, published pieces, and thematic series.</p>
        </article>
        <article class="feature-card">
          <h3>Progressive Expansion</h3>
          <p>The current release is intentionally lean and ready for additional scholarly sections.</p>
        </article>
      </div>
    </section>

    <section class="shell section">
      <div class="grid-two">
        <article class="content-card">
          <p class="content-card__meta">Available now</p>
          <h3>Clear structure and stable navigation</h3>
          <p>
            The current interface focuses on clarity, readability, and a dependable launch-ready
            foundation for the main public sections.
          </p>
        </article>
        <article class="content-card">
          <p class="content-card__meta">Coming next</p>
          <h3>Approved content and richer scholarly detail</h3>
          <p>
            The next updates will replace placeholder text with approved biography, publication
            data, article entries, and specialized research-oriented sections.
          </p>
        </article>
      </div>
    </section>

    <section class="shell cta-panel">
      <div>
        <p class="section-kicker">Start here</p>
        <h2 class="section-title">Explore the current edition</h2>
        <p class="section-copy">
          Begin with the profile pages or move directly to books, critical editions, and articles.
        </p>
      </div>
      <div class="hero__actions">
        <a class="button" href="/en/about/">About</a>
        <a class="button-secondary" href="/en/cv/">CV</a>
      </div>
    </section>
  </main>
</BaseLayout>
