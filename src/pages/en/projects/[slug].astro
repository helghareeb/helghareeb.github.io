---
import { getCollection, render } from 'astro:content';
import EntityEntryPage from '../../../components/EntityEntryPage.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import { getEntryRouteSlug } from '../../../utils/content-routing';
import { buildSeoDescription, buildSeoTitle } from '../../../utils/seo';

export async function getStaticPaths() {
  const entries = (await getCollection('projects')).filter((entry) => entry.data.lang === 'en');

  return entries.map((entry) => ({
    params: { slug: getEntryRouteSlug(entry.slug) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const seoTitle = buildSeoTitle(entry.data.title, { lang: 'en', section: 'Projects' });
const seoDescription = buildSeoDescription(entry.data.summary, [
  entry.data.area,
  entry.data.status,
  entry.data.startYear ? `Started ${entry.data.startYear}` : undefined,
]);
---

<BaseLayout lang="en" dir="ltr" title={seoTitle} description={seoDescription}>
  <EntityEntryPage
    lang="en"
    eyebrow="Project"
    title={entry.data.title}
    summary={entry.data.summary}
    badges={['Project page', 'Standalone entry', entry.data.status ?? 'Available record']}
    metaItems={[
      { label: 'Section', value: 'Projects' },
      { label: 'Status', value: entry.data.status ?? 'Unspecified' },
      ...(entry.data.area ? [{ label: 'Area', value: entry.data.area }] : []),
      ...(entry.data.startYear ? [{ label: 'Start year', value: entry.data.startYear }] : []),
    ]}
    backHref="/en/projects/"
    backLabel="Back to projects"
    externalUrl={entry.data.externalUrl}
    externalLabel="Project link"
  >
    <Content />
  </EntityEntryPage>
</BaseLayout>
