---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import '../../../../styles/global.css';
import { buildSeoDescription, buildSeoTitle } from '../../../../utils/seo';

const seoTitle = buildSeoTitle('Academic reviewing and assessment experience', {
  lang: 'en',
  section: 'Academic Reviewing',
});
const seoDescription = buildSeoDescription(
  'A concise public-facing presentation of academic reviewing and assessment experience within the scholarly website.',
  ['Reviewing experience', 'Selective presentation'],
);
---

<BaseLayout
  lang="en"
  dir="ltr"
  title={seoTitle}
  description={seoDescription}
>
  <main class="page-main page-main--detail">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">Academic Reviewing</p>
      <h1 class="hero__title">A concise view of reviewing and assessment experience</h1>
      <p class="hero__lead">
        This section presents reviewing experience in a concise public-facing form
        while keeping the emphasis on the nature of the work rather than unnecessary detail.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">Reviewing experience</span>
        <span class="hero__badge">Concise presentation</span>
      </div>
    </section>

    <section class="shell notice-card">
      <h2 class="section-title">Presentation style</h2>
      <p>
        In line with the project documentation, this area remains brief and selective,
        highlighting expertise without overloading the page with detail.
      </p>
    </section>
  </main>
</BaseLayout>
