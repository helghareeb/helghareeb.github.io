---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import '../../../../styles/global.css';
import { buildSeoDescription, buildSeoTitle } from '../../../../utils/seo';

const seoTitle = buildSeoTitle('AI and Islamic Heritage', {
  lang: 'en',
  section: 'Scholarly Field',
});
const seoDescription = buildSeoDescription(
  'A field page connecting AI, digital tools, and the service of Islamic heritage through projects, analytical articles, and conceptual framing.',
  ['Digital vision', 'Applied scholarly projects'],
);
---

<BaseLayout
  lang="en"
  dir="ltr"
  title={seoTitle}
  description={seoDescription}
>
  <main class="page-main page-main--detail">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">AI and Islamic Heritage</p>
      <h1 class="hero__title">A space for digital vision in the service of heritage</h1>
      <p class="hero__lead">
        This section highlights the relationship between contemporary digital tools and the service
        of Islamic heritage, including organization, archival thinking, and applied scholarly projects.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">Digital vision</span>
        <span class="hero__badge">Applied projects</span>
      </div>
    </section>

    <section class="shell section">
      <div class="grid-three">
        <article class="feature-card">
          <h3>Conceptual framing</h3>
          <p>Clarifying how modern tools can serve scholarship responsibly and fruitfully.</p>
        </article>
        <article class="feature-card">
          <h3>Applied projects</h3>
          <p>Highlighting initiatives that work with data, texts, and research workflows.</p>
        </article>
        <article class="feature-card">
          <h3>Analytical articles</h3>
          <p>Collecting essays that examine the field from methodological and scholarly angles.</p>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
