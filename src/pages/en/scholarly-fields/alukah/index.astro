---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import '../../../../styles/global.css';
import { buildSeoDescription, buildSeoTitle } from '../../../../utils/seo';

const seoTitle = buildSeoTitle('Alukah publications gateway', {
  lang: 'en',
  section: 'Alukah',
});
const seoDescription = buildSeoDescription(
  'Gateway to Alukah-related content inside the site, including article lists, summaries, and source links.',
  ['External publications', 'Connected article archive'],
);
---

<BaseLayout
  lang="en"
  dir="ltr"
  title={seoTitle}
  description={seoDescription}
>
  <main class="page-main page-main--detail">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">Alukah</p>
      <h1 class="hero__title">An internal gateway to Alukah publications</h1>
      <p class="hero__lead">
        This section gathers Alukah articles in one place and presents them
        as part of the broader scholarly archive rather than as isolated external links.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">External publications</span>
        <span class="hero__badge">Summaries and links</span>
      </div>

      <div class="hero__actions">
        <a class="button" href="/en/scholarly-fields/alukah/articles/">English Alukah list</a>
        <a class="button-secondary" href="/en/external-links/alukah-author-page/">Author page on Alukah</a>
      </div>
    </section>

    <section class="shell section">
      <div class="grid-two">
        <article class="content-card">
          <p class="content-card__meta">Structure</p>
          <h2 class="section-title">Summaries and source links</h2>
          <p>
            Entries can include the article title, summary, original source link, category,
            and whether a local site version also exists.
          </p>
        </article>
        <article class="content-card">
          <p class="content-card__meta">Integration</p>
          <h2 class="section-title">Connected to the article archive</h2>
          <p>
            Alukah content can also surface through the general articles section wherever thematic
            overlap or archive logic makes that useful.
          </p>
        </article>
      </div>
    </section>

    <section class="shell notice-card">
      <h2 class="section-title">Direct archive access</h2>
      <p>
        A dedicated list of English Alukah articles is available here:
        <a href="/en/scholarly-fields/alukah/articles/">English Alukah articles inside the site</a>.
      </p>
    </section>
  </main>
</BaseLayout>
