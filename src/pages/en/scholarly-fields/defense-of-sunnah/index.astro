---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import '../../../../styles/global.css';
import { buildSeoDescription, buildSeoTitle } from '../../../../utils/seo';

const seoTitle = buildSeoTitle('Defense of Sunnah', {
  lang: 'en',
  section: 'Scholarly Field',
});
const seoDescription = buildSeoDescription(
  'A specialized field page for responses to objections, structured clarification, and connected series in defense of the Sunnah.',
  ['Responses and series', 'Methodical scholarly treatment'],
);
---

<BaseLayout
  lang="en"
  dir="ltr"
  title={seoTitle}
  description={seoDescription}
>
  <main class="page-main page-main--detail">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">Defense of Sunnah</p>
      <h1 class="hero__title">A section for structured scholarly response</h1>
      <p class="hero__lead">
        This area gathers writing that addresses objections, misunderstandings, and
        thematic defenses of Sunnah in a methodical and organized way.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">Specialized section</span>
        <span class="hero__badge">Responses and series</span>
      </div>
    </section>

    <section class="shell notice-card">
      <h2 class="section-title">Section focus</h2>
      <p>
        The section brings together standalone essays, connected series, and topic-based grouping
        to help readers navigate questions and responses coherently.
      </p>
    </section>
  </main>
</BaseLayout>
