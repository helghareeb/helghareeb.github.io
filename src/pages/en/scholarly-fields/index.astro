---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import { buildSeoDescription, buildSeoTitle } from '../../../utils/seo';

const fieldCards = [
  {
    title: 'Islamic Studies',
    copy: 'The broad umbrella for scholarship related to Islamic heritage, Hadith studies, methodology, and connected fields.',
    href: '/en/scholarly-fields/islamic-studies/',
  },
  {
    title: 'Defense of Sunnah',
    copy: 'A dedicated space for structured responses, thematic series, and reasoned scholarly clarification.',
    href: '/en/scholarly-fields/defense-of-sunnah/',
  },
  {
    title: 'Alukah',
    copy: 'A distinct area for collecting Alukah articles and connecting them to summaries and internal site organization.',
    href: '/en/scholarly-fields/alukah/',
  },
  {
    title: 'Manuscripts',
    copy: 'A section for manuscript-related interests, including description, editing, method, and editorial practice.',
    href: '/en/scholarly-fields/manuscripts/',
  },
  {
    title: 'AI and Islamic Heritage',
    copy: 'A forward-looking area focused on applying digital tools to the service of Islamic heritage and knowledge.',
    href: '/en/scholarly-fields/ai-and-islamic-heritage/',
  },
  {
    title: 'Academic Reviewing',
    copy: 'A concise public-facing presentation of reviewing experience and the general nature of assessed academic work.',
    href: '/en/scholarly-fields/academic-reviewing/',
  },
  {
    title: 'E-Learning in Islamic Studies',
    copy: 'A section for educational initiatives and digital approaches to structured Islamic learning.',
    href: '/en/scholarly-fields/e-learning/',
  },
];
const seoTitle = buildSeoTitle('Specialized scholarly fields', {
  lang: 'en',
  section: 'Scholarly Fields',
});
const seoDescription = buildSeoDescription(
  'English gateway to the site’s specialized scholarly fields, including Islamic Studies, Defense of Sunnah, Alukah, manuscripts, AI and Islamic heritage, reviewing, and e-learning.',
  [`${fieldCards.length} specialized areas`],
);
---

<BaseLayout
  lang="en"
  dir="ltr"
  title={seoTitle}
  description={seoDescription}
>
  <main class="page-main">
    <section class="shell hero hero--portal">
      <p class="hero__eyebrow">Scholarly Fields</p>
      <h1 class="hero__title">A gateway to the site's specialized scholarly areas</h1>
      <p class="hero__lead">
        This page introduces the major scholarly fields represented across the site and
        gathers the main areas through which articles, archives, and related scholarly work are organized.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">Gateway page</span>
        <span class="hero__badge">Specialized fields</span>
        <span class="hero__badge">Connected growth paths</span>
      </div>

      <div class="hero__actions">
        <a class="button" href="/en/articles/">Browse articles</a>
        <a class="button-secondary" href="/en/learning-path/">Suggested learning path</a>
      </div>
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">Project structure</p>
        <h2 class="section-title">Fields anchored in the current site plan</h2>
        <p class="section-copy">
          The current implementation provides a clear entry point for these areas, with
          dedicated pages and a structure that supports deeper series and internal navigation.
        </p>
      </div>

      <div class="grid-three">
        {fieldCards.map((field) => (
          <a class="card-link" href={field.href}>
          <article class="feature-card feature-card--field">
            <h3>{field.title}</h3>
            <p>{field.copy}</p>
          </article>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
