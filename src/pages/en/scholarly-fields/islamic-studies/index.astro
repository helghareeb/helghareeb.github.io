---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import '../../../../styles/global.css';
import { buildSeoDescription, buildSeoTitle } from '../../../../utils/seo';

const seoTitle = buildSeoTitle('Islamic Studies', {
  lang: 'en',
  section: 'Scholarly Field',
});
const seoDescription = buildSeoDescription(
  'The broadest scholarly field in the site, linking Islamic heritage, Hadith, methodology, and related content across the archive.',
  ['Linked archives', 'Related scholarly content'],
);
---

<BaseLayout
  lang="en"
  dir="ltr"
  title={seoTitle}
  description={seoDescription}
>
  <main class="page-main page-main--detail">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">Islamic Studies</p>
      <h1 class="hero__title">The broadest scholarly umbrella of the project</h1>
      <p class="hero__lead">
        This section gathers the major Islamic studies themes connected to the site,
        and to serve as a conceptual frame linking the more specialized areas.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">Specialized section</span>
        <span class="hero__badge">Article-linked</span>
        <span class="hero__badge">Archive-ready</span>
      </div>
    </section>

    <section class="shell section">
      <div class="grid-two">
        <article class="content-card">
          <p class="content-card__meta">Purpose</p>
          <h2 class="section-title">A general entry point</h2>
          <p>
            It gathers articles, works, and themes related to Islamic heritage, Hadith,
            method, and neighboring scholarly concerns.
          </p>
        </article>
        <article class="content-card">
          <p class="content-card__meta">Expansion</p>
          <h2 class="section-title">Linked archives and related content</h2>
          <p>
            The section supports internal archives and thematic connections across books, articles,
            and critical editions.
          </p>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
