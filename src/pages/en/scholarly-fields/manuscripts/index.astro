---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import '../../../../styles/global.css';
import { buildSeoDescription, buildSeoTitle } from '../../../../utils/seo';

const seoTitle = buildSeoTitle('Manuscripts', {
  lang: 'en',
  section: 'Scholarly Field',
});
const seoDescription = buildSeoDescription(
  'A field page for manuscript studies, description, editorial method, and broader methodological questions tied to textual heritage.',
  ['Manuscripts', 'Description and editing'],
);
---

<BaseLayout
  lang="en"
  dir="ltr"
  title={seoTitle}
  description={seoDescription}
>
  <main class="page-main page-main--detail">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">Manuscripts</p>
      <h1 class="hero__title">Manuscripts between description, editing, and method</h1>
      <p class="hero__lead">
        This section gathers manuscript-related scholarly interests, including description,
        editorial method, and the broader questions tied to textual heritage work.
      </p>

      <div class="hero__badge-row">
        <span class="hero__badge">Manuscripts</span>
        <span class="hero__badge">Description and editing</span>
      </div>
    </section>

    <section class="shell notice-card">
      <h2 class="section-title">Directly related to critical editions</h2>
      <p>
        It works alongside the critical editions section while also hosting broader
        methodological or reflective material about manuscript scholarship.
      </p>
    </section>
  </main>
</BaseLayout>
