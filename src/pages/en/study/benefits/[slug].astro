---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import EntityEntryPage from '../../../../components/EntityEntryPage.astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import '../../../../styles/global.css';
import { buildSeoDescription, buildSeoTitle } from '../../../../utils/seo';
import { getStudyBenefitBookPath, getStudyBenefitRouteSlug } from '../../../../utils/study';

export async function getStaticPaths() {
  const entries = (await getCollection('studyBenefits')).filter((entry) => entry.data.lang === 'en' && !entry.data.draft);

  return entries.map((entry) => ({
    params: { slug: getStudyBenefitRouteSlug(entry.slug) },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'studyBenefits'> };
const { Content } = await render(entry);
const seoTitle = buildSeoTitle(entry.data.title, {
  lang: 'en',
  section: 'Benefits from Books',
});
const seoDescription = buildSeoDescription(entry.data.summary, [
  entry.data.field,
  entry.data.bookTitle,
  entry.data.teacher,
]);
---

<BaseLayout lang="en" dir="ltr" title={seoTitle} description={seoDescription}>
  <EntityEntryPage
    lang="en"
    eyebrow="Study notebook"
    title={entry.data.title}
    summary={entry.data.summary}
    badges={['Structured benefits', entry.data.field, entry.data.bookTitle]}
    metaItems={[
      { label: 'Section', value: 'Study Hub' },
      { label: 'Track', value: 'Benefits from Books' },
      { label: 'Field', value: entry.data.field },
      { label: 'Book', value: entry.data.bookTitle },
      ...(entry.data.teacher ? [{ label: 'Lesson source', value: entry.data.teacher }] : []),
      ...(entry.data.sourceSeries ? [{ label: 'Study source', value: entry.data.sourceSeries }] : []),
    ]}
    backHref={getStudyBenefitBookPath('en', entry.data.fieldSlug, entry.data.bookSlug)}
    backLabel="Back to the book page"
  >
    <section class="notice-card">
      <p class="entity-kicker">Editorial note</p>
      <h2 class="section-title">These notes were prepared for the site</h2>
      <p>
        These published notes were organized and edited for study use on the site. The teacher did
        not review this published version and it was not submitted to him for checking.
      </p>
    </section>

    <Content />
  </EntityEntryPage>
</BaseLayout>
