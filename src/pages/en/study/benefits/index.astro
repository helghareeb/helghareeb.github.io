---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import '../../../../styles/global.css';
import { buildSeoDescription, buildSeoTitle } from '../../../../utils/seo';
import { getEntryPath } from '../../../../utils/content-routing';
import { getStudyBenefitBookPath, groupStudyBenefits, getStudyBenefitRouteSlug } from '../../../../utils/study';

const publishedBenefits = (await getCollection('studyBenefits')).filter(
  (entry) => entry.data.lang === 'en' && !entry.data.draft,
);
const groupedBenefits = groupStudyBenefits(publishedBenefits);

const seoTitle = buildSeoTitle('Benefits from Books', {
  lang: 'en',
  section: 'Study Hub',
});
const seoDescription = buildSeoDescription(
  'A study-notes track that will organize selected benefits by field and book, with lesson-source context where needed.',
  [
    `${publishedBenefits.length} published notes at present`,
    'Starting from al-Risalah and al-Tabari-related material',
  ],
);
---

<BaseLayout lang="en" dir="ltr" title={seoTitle} description={seoDescription}>
  <main class="page-main">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">Benefits from Books</p>
      <h1 class="hero__title">An archive ordered by field and book</h1>
      <p class="hero__lead">
        This track is designed to gather concise study benefits drawn from lessons and book-based
        teaching, with a structure that takes the student from discipline to book to note.
      </p>
    </section>

    <section class="shell entity-grid">
      <article class="entity-summary">
        <p class="entity-kicker">Organization</p>
        <h2 class="section-title">From discipline to book to benefit</h2>
        <p class="section-copy">
          The working structure begins with the discipline, then gathers notes under the book,
          while still preserving teacher or lesson-source context when that matters for study use.
        </p>
      </article>

      <article class="entity-panel">
        <p class="entity-kicker">Current state</p>
        <ul class="entity-list">
          <li><strong>Published notes:</strong> {publishedBenefits.length}</li>
          <li><strong>Books currently shown:</strong> {groupedBenefits.length}</li>
          <li><strong>Current starting point:</strong> al-Risalah through Dr. Ahmad al-Naqeeb's lessons</li>
        </ul>
      </article>
    </section>

    <section class="shell section">
      <div class="section-heading">
        <p class="section-kicker">Published books</p>
        <h2 class="section-title">Benefits arranged by field and then by book</h2>
      </div>

      {groupedBenefits.length === 0 ? (
        <article class="notice-card">
          <h2 class="section-title">No study notebooks have been published yet</h2>
          <p>The structure is ready, and the first visible material here begins with al-Risalah and later related study notebooks.</p>
        </article>
      ) : (
        <div class="grid-two">
          {groupedBenefits.map((group) => (
            <article class="content-card entity-card">
              <p class="content-card__meta">{group.field}</p>
              <h3>
                <a href={getStudyBenefitBookPath('en', group.fieldSlug, group.bookSlug)}>{group.bookTitle}</a>
              </h3>
              <p>{group.teacher ?? 'Organized study material inside the site'}</p>
              <p class="content-card__meta">{group.entries.length} study notebooks</p>
              <ul class="entity-list">
                {group.entries.map((entry) => (
                  <li>
                    <a href={getEntryPath('studyBenefits', 'en', getStudyBenefitRouteSlug(entry.slug))}>{entry.data.title}</a>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      )}
    </section>
  </main>
</BaseLayout>
