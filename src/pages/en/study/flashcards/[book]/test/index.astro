---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../../../../layouts/BaseLayout.astro';
import '../../../../../../styles/global.css';
import { buildSeoDescription, buildSeoTitle } from '../../../../../../utils/seo';

export async function getStaticPaths() {
  const decks = await getCollection('flashcardDecks');

  return decks
    .filter((entry) => entry.data.lang === 'en' && !entry.data.draft)
    .map((entry) => ({
      params: { book: entry.slug.replace(/-(ar|en)$/, '') },
      props: { deck: entry },
    }));
}

const { deck } = Astro.props as { deck: CollectionEntry<'flashcardDecks'> };
const cards = (await getCollection('flashcards'))
  .filter(
    (entry) =>
      entry.data.lang === 'en' &&
      !entry.data.draft &&
      entry.data.deckSlug === deck.slug.replace(/-(ar|en)$/, '') &&
      entry.data.mode === 'test',
  )
  .sort((a, b) => a.data.order - b.data.order);
const seoTitle = buildSeoTitle(`Test ${deck.data.bookTitle}`, {
  lang: 'en',
  section: 'Flashcards',
});
const seoDescription = buildSeoDescription(deck.data.summary, [`${cards.length} test questions`]);
---

<BaseLayout lang="en" dir="ltr" title={seoTitle} description={seoDescription}>
  <main class="page-main">
    <section class="shell hero hero--detail">
      <p class="hero__eyebrow">Test</p>
      <h1 class="hero__title">Test mode for {deck.data.bookTitle}</h1>
      <p class="hero__lead">
        This mode presents the questions in assessment form so the learner can measure retention
        before returning to review or the later results workflow.
      </p>
    </section>

    <section class="shell section">
      {cards.length === 0 ? (
        <article class="notice-card">
          <h2 class="section-title">No test questions have been published yet</h2>
          <p>This page is ready for later test batches and the connection to the results-and-retry flow.</p>
        </article>
      ) : (
        <div class="grid-two">
          {cards.map((card) => (
            <article class="content-card entity-card">
              <p class="content-card__meta">Question {card.data.order}</p>
              <h3>{card.data.question}</h3>
            </article>
          ))}
        </div>
      )}
    </section>
  </main>
</BaseLayout>
