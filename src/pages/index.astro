---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout
  lang="ar"
  dir="rtl"
  title="الموقع الشخصي العلمي | د. هيثم الغريب"
  description="النسخة الجديدة قيد الإعداد من الموقع الشخصي العلمي للدكتور هيثم الغريب"
>
  <main style="padding: 4rem 1rem; max-width: 960px; margin: 0 auto;">
    <h1>الموقع الشخصي العلمي للدكتور هيثم الغريب</h1>
    <p>
      هذه نسخة أولية قيد الإعداد ضمن مشروع إعادة بناء الموقع الشخصي العلمي بصورة حديثة،
      ثنائية اللغة، تجمع بين الطابع الأكاديمي والتراثي.
    </p>
    <p>
      يجري حاليًا تجهيز البنية الجديدة للموقع لتشمل الكتب، والتحقيقات، والمقالات،
      والدراسات الإسلامية، والمخطوطات، والمشروعات العلمية، والمواد الصوتية والمرئية.
    </p>
  </main>
</BaseLayout>
