---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout
  lang="ar"
  dir="rtl"
  title="الموقع الشخصي العلمي | د. هيثم الغريب"
  description="بوابة ثنائية اللغة للموقع الشخصي العلمي للدكتور هيثم الغريب"
>
  <main class="page-main">
    <section class="shell hero">
      <p class="hero__eyebrow">بوابة الدخول</p>
      <h1 class="hero__title">الموقع الشخصي العلمي للدكتور هيثم الغريب</h1>
      <p class="hero__lead">
        نسخة ثنائية اللغة للموقع العلمي، تجمع بين التعريف الأكاديمي، والإنتاج العلمي،
        والمحتوى البحثي، وخطط التوسع في الكتب والتحقيقات والمقالات والمشروعات.
      </p>

      <div class="hero__actions">
        <a class="button" href="/ar/">الدخول إلى النسخة العربية</a>
        <a class="button-secondary" href="/en/">Enter the English version</a>
      </div>
    </section>
  </main>
</BaseLayout>
